# Copiar a .env y completar. El .env real JAMÁS se commitea.

# Postgres (local: Homebrew/Docker; prod: Supabase/Neon)
# Nombre propio (no DATABASE_URL) para no chocar con env vars globales del shell.
BARDOOO_DATABASE_URL="postgresql://usuario@localhost:5432/bardooo"

# Privy (dashboard.privy.io → tu app → API keys)
PRIVY_APP_ID=""
PRIVY_APP_SECRET=""
